MINIMAX_API_KEY=PUT_YOUR_KEY_HERE
#optional base path for output files
MINIMAX_API_HOST=https://api.minimax.chat
# optional MCP server transport: stdio | sse | streamable
# MINIMAX_MCP_TRANSPORT=stdio
# optional network listen host, used by sse / streamable transports
# MINIMAX_MCP_HOST=0.0.0.0
# optional network listen port, used by sse / streamable transports
# MINIMAX_MCP_PORT=8000
# optional bearer token for sse / streamable transports
# MINIMAX_MCP_BEARER_TOKEN=PUT_YOUR_BEARER_TOKEN_HERE
#optional resource mode[url, local], default is url
# MINIMAX_API_RESOURCE_MODE=local
